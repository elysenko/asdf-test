# Database (set by db_agent / Helm release)
DATABASE_URL=postgresql://postgres:CHANGE_ME@city-weather-search-postgresql.colossus-apps.svc.cluster.local:5432/city_weather_search_db

# Optional cache (not used by backend yet, but provisioned)
REDIS_URL=redis://:CHANGE_ME@city-weather-search-redis-master.colossus-apps.svc.cluster.local:6379

# Upstream provider API keys.
# We use OpenWeatherMap for both geocoding and weather. The two variables let you
# swap providers (or rotate keys) independently. Both are required at runtime.
GEOCODER_API_KEY=
WEATHER_API_KEY=

# Optional: override upstream timeouts (milliseconds).
GEOCODER_TIMEOUT_MS=1500
WEATHER_TIMEOUT_MS=1500

# Optional: override upstream base URLs (useful for tests / mocks).
GEOCODER_BASE_URL=https://api.openweathermap.org/geo/1.0
WEATHER_BASE_URL=https://api.openweathermap.org/data/2.5
